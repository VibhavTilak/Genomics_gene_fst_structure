# =========================
# ASSIGN FUNCTIONAL GROUP
# Candidate groups always take priority
# =========================
assign_group <- function(gene) {
  if (gene %in% plumage_development)          return("Plumage development")
  if (gene %in% iris_color)                   return("Iris coloration")
  if (gene %in% neural_synapse_genes)         return("Neural & synaptic")
  if (gene %in% ribosomal_translation_genes)  return("Ribosomal & translation")
  if (gene %in% mirna_genes)                  return("miRNA")
  if (gene %in% metabolic_biosynthetic_genes) return("Metabolic & biosynthetic")
  if (gene %in% immune_regulatory_genes)      return("Immune & regulatory")
  if (gene %in% membrane_transport_genes)     return("Membrane & transport")
  if (grepl("^LOC|^RPL|^RPS", gene))          return("Uncharacterized")
  return("Other")
}

