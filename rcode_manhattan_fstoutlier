# =========================
# FUNCTION: READ FST
# =========================
read_fst <- function(fst_file) {
  cat("  Reading FST file...\n")
  fst <- fread(fst_file, header = FALSE,
               col.names = c("chr","pos","alpha","beta"))
  fst <- fst[beta > 0]
  fst[, pos_end := pos]
  setkey(fst, chr, pos, pos_end)
  return(fst)
}

# =========================
# FUNCTION: COMPUTE GENE FST (Bhatia et al. 2013)
# =========================
compute_gene_fst <- function(fst_dt, genes_dt) {
  regions <- copy(genes_dt)
  setkey(regions, chr, gene_start, gene_end)
  cat("  Overlapping sites with genes...\n")
  joined <- foverlaps(fst_dt, regions,
                      by.x = c("chr","pos","pos_end"),
                      by.y = c("chr","gene_start","gene_end"),
                      type = "within", nomatch = NULL)
  result <- joined[, .(
    n_sites  = .N,
    fst_gene = sum(alpha) / sum(beta)
  ), by = .(chr, gene_start, gene_end, gene, group)]
  cat("  Genes with FST data:", nrow(result), "\n")
  return(result)
}

# =========================
# FUNCTION: BUILD SCAFFOLD OFFSETS FOR X-AXIS
# =========================
build_offsets <- function(df) {
  scaffold_order <- df %>%
    group_by(chr) %>%
    summarise(max_pos = max(gene_end), .groups = "drop") %>%
    arrange(desc(max_pos)) %>%
    pull(chr)
  GAP <- 2e6
  offsets <- setNames(numeric(length(scaffold_order)), scaffold_order)
  cum <- 0
  for (sc in scaffold_order) {
    offsets[sc] <- cum
    cum <- cum + max(df$gene_end[df$chr == sc]) + GAP
  }
  return(offsets)
}

# =========================
# FUNCTION: MAKE MANHATTAN PLOTS (all genes + top 95%)
# =========================
make_manhattan <- function(df, pair_name) {
  
  df <- df %>%
    filter(!is.na(fst_gene), n_sites >= 5) %>%
    mutate(
      gene_mid     = (gene_start + gene_end) / 2,
      is_candidate = gene %in% all_candidates,
      group        = factor(group, levels = names(group_colours))
    )
  
  if (nrow(df) == 0) { cat("  No data — skipping\n"); return(invisible(NULL)) }
  
  fst_95  <- quantile(df$fst_gene, 0.95, na.rm = TRUE)
  fst_99  <- quantile(df$fst_gene, 0.99, na.rm = TRUE)
  offsets <- build_offsets(df)
  df      <- df %>% mutate(x_pos = gene_mid + offsets[chr])
  
  scaffold_labels <- df %>%
    group_by(chr) %>%
    summarise(x_mid = mean(x_pos), n = n(), .groups = "drop") %>%
    filter(n >= 3) %>%
    mutate(chr_label = gsub("JBVOHZ0100+0*", "Sc", chr))
  
  # one label per candidate at its highest FST point
  label_df <- df %>%
    filter(is_candidate) %>%
    group_by(gene) %>%
    slice_max(fst_gene, n = 1) %>%
    ungroup()
  
  # shared theme
  shared_theme <- list(
    geom_hline(yintercept = fst_95, linetype = "dashed",
               colour = "grey50", linewidth = 0.4),
    geom_hline(yintercept = fst_99, linetype = "solid",
               colour = "grey20", linewidth = 0.5),
    scale_colour_manual(
      values = group_colours, name = "Functional group",
      guide  = guide_legend(override.aes = list(size = 3.5, alpha = 1), ncol = 2)
    ),
    scale_size_manual(values  = group_size,  guide = "none"),
    scale_alpha_manual(values = group_alpha, guide = "none"),
    scale_x_continuous(breaks = scaffold_labels$x_mid,
                       labels = scaffold_labels$chr_label),
    labs(x = "Scaffolds",
         y = expression(F[ST]~"(Bhatia et al. 2013)")),
    theme_classic(base_size = 11),
    theme(
      axis.text.x        = element_text(angle = 45, hjust = 1, size = 6),
      axis.ticks.x       = element_line(linewidth = 0.3),
      legend.position    = "bottom",
      legend.text        = element_text(size = 8),
      legend.title       = element_text(size = 9, face = "bold"),
      legend.key.size    = unit(0.4, "cm"),
      plot.title         = element_text(face = "bold", size = 12),
      plot.subtitle      = element_text(size = 9, colour = "grey40"),
      panel.grid.major.y = element_line(colour = "grey95", linewidth = 0.3)
    )
  )
  
  repel_labels <- function(data) {
    ggrepel::geom_text_repel(
      data = data, aes(label = gene),
      colour = "black", size = 2.8, fontface = "bold",
      max.overlaps = 100, box.padding = 0.5, point.padding = 0.3,
      segment.color = "grey40", segment.size = 0.3,
      min.segment.length = 0.1
    )
  }
  
  pct_labels <- function(df_plot) {
    xmax <- max(df_plot$x_pos, na.rm = TRUE) * 0.98
    list(
      annotate("text", x = xmax, y = fst_95, label = "95th pct",
               hjust = 1, vjust = -0.4, size = 2.5, colour = "grey50"),
      annotate("text", x = xmax, y = fst_99, label = "99th pct",
               hjust = 1, vjust = -0.4, size = 2.5, colour = "grey20")
    )
  }
  
  # ── ALL GENES ──────────────────────────────────────────────────────────────
  p_all <- ggplot(df, aes(x = x_pos, y = fst_gene)) +
    geom_point(data = df %>% filter(!is_candidate),
               aes(colour = group, size = group, alpha = group)) +
    geom_point(data = df %>% filter(is_candidate),
               aes(colour = group, size = group), alpha = 1.0) +
    repel_labels(label_df) +
    shared_theme +
    pct_labels(df) +
    labs(title    = expression("Genome-wide"~F[ST]~"— all genes"),
         subtitle = paste0(gsub("_"," ", pair_name),
                           "  |  Mixornis gularis reference"))
  
  ggsave(file.path(OUTDIR, paste0("manhattan_all_", pair_name, ".png")),
         p_all, width = 20, height = 6, dpi = 300)
  cat("  Saved: manhattan_all_", pair_name, ".png\n", sep = "")
  
  # ── TOP 95% ONLY ───────────────────────────────────────────────────────────
  df_top    <- df %>% filter(fst_gene >= fst_95)
  label_top <- label_df %>% filter(fst_gene >= fst_95)
  
  if (nrow(df_top) > 0) {
    p_top <- ggplot(df_top, aes(x = x_pos, y = fst_gene)) +
      geom_point(data = df_top %>% filter(!is_candidate),
                 aes(colour = group, size = group, alpha = group)) +
      geom_point(data = df_top %>% filter(is_candidate),
                 aes(colour = group, size = group), alpha = 1.0) +
      repel_labels(label_top) +
      shared_theme +
      pct_labels(df_top) +
      labs(title    = expression("Genome-wide"~F[ST]~"— top 95th percentile"),
           subtitle = paste0(gsub("_"," ", pair_name),
                             "  |  Mixornis gularis reference"))
    
    ggsave(file.path(OUTDIR, paste0("manhattan_top95_", pair_name, ".png")),
           p_top, width = 20, height = 6, dpi = 300)
    cat("  Saved: manhattan_top95_", pair_name, ".png\n", sep = "")
  }
  
  # ── SAVE TABLE ─────────────────────────────────────────────────────────────
  top_tbl <- df_top %>%
    arrange(desc(fst_gene)) %>%
    mutate(
      percentile   = ifelse(fst_gene >= fst_99, "top1pct", "top5pct"),
      is_candidate = gene %in% all_candidates
    ) %>%
    select(chr, gene_start, gene_end, gene, group,
           n_sites, fst_gene, percentile, is_candidate)
  
  write.table(top_tbl,
              file = file.path(OUTDIR, paste0("top_genes_", pair_name, ".tsv")),
              sep = "\t", quote = FALSE, row.names = FALSE)
  
  cat("  Top genes:", nrow(top_tbl),
      "| candidates in top 95%:", sum(top_tbl$is_candidate), "\n")
}

